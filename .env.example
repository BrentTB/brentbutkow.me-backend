# Postgres connection string — Railway injects DATABASE_URL automatically in production.
# Accepts postgresql:// or postgres://; the app normalizes it to the psycopg driver.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recall_radar

# Shared secret guarding POST /recalls/ingest. Generate with: openssl rand -hex 32
INGEST_BEARER_TOKEN=replace-with-a-long-random-token

# Allowed CORS origin for browser reads (your site). Comma-separate to allow several.
ALLOWED_ORIGIN=http://localhost:5173

# Port the server listens on — Railway sets PORT automatically.
PORT=3000

# Optional openFDA API key — raises rate limits. Not required for the daily cron.
OPENFDA_API_KEY=
