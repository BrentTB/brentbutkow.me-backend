# Postgres connection string — in production set this to your Neon URL (in Render's env vars).
# Accepts postgresql:// or postgres://; the app normalizes it to the psycopg driver.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recall_radar

# Shared secret guarding the POST /recalls/ingest/* endpoints. Generate with: openssl rand -hex 32
INGEST_BEARER_TOKEN=replace-with-a-long-random-token

# Allowed CORS origins for browser reads (your site). Comma-separate to allow several.
# Each entry is matched exactly and MUST include the scheme. Production example:
#   https://brentbutkow.me,https://brentbutkowme.vercel.app
ALLOWED_ORIGIN=http://localhost:5173

# Optional regex matched in ADDITION to ALLOWED_ORIGIN, for origins whose subdomain changes
# per deploy (e.g. Vercel preview links). Anchor it to your own Vercel scope — never a blanket
# *.vercel.app, which would let any site on Vercel read the API.
ALLOWED_ORIGIN_REGEX=

# Port the server listens on — Render sets PORT automatically.
PORT=3000

# Optional openFDA API key — raises rate limits. Not required for the daily cron.
OPENFDA_API_KEY=

# Trusted reverse-proxy hops in front of the app, so per-IP rate limiting reads the real client
# from X-Forwarded-For instead of the proxy's IP. 0 for local/Docker (direct), 1 behind Render.
TRUSTED_PROXY_HOPS=0

# ---------------------------------------------------------------------------
# Recall Radar — Subscription alerts (recall-radar-subscriptions feature)
# ---------------------------------------------------------------------------

# Resend API key for sending transactional email (opt-in, digest, operator summary).
# Get yours at https://resend.com — the free tier allows 100 emails/day.
# When absent, email sending is disabled gracefully (subscriptions still work locally).
RESEND_API_KEY=

# Sender address shown in all outbound emails. Must be a verified domain in your Resend account.
# Defaults to recalls@notify.brentbutkow.me when unset.
RESEND_FROM_ADDRESS=recalls@notify.brentbutkow.me

# Operator email address that receives the daily operator digest (metrics + full recall list).
# When absent, the operator digest is skipped with a WARNING log.
OPERATOR_EMAIL=

# Shared secret for the POST /internal/dispatch-alerts endpoint, called by GitHub Actions
# after each successful ingest run. Generate with: openssl rand -hex 32
# Add the same value as the INTERNAL_DISPATCH_TOKEN GitHub Actions secret in your repo.
INTERNAL_DISPATCH_TOKEN=replace-with-a-long-random-token
